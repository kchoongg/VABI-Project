              <calculation class='tableau' formula='IF [release_year] &lt;= 2026 THEN &quot;Early / Ivy Echoes Era&quot;&#13;&#10;ELSEIF [release_year] &lt; 2028 THEN &quot;Transition&quot;&#13;&#10;ELSE &quot;Breakthrough and After&quot;&#13;&#10;END' />
