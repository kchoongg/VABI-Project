      <column caption='Genre Exchange Total' datatype='integer' name='[Calculation_1489342781087753]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1489342780968966] + [Calculation_1489342781009927]' />
      </column>
      <column caption='12_How_Oceanus_Folk_Changed_With_Sailor' datatype='string' name='[Calculation_1489342818107416]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [direction] = &quot;Other -&gt; OF&quot; THEN [source_genre] END' />
      </column>
      <column caption='before_2028_influences' datatype='integer' name='[Calculation_1489342818156569]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Calculation_1489342818275354] :&#13;&#10;    COUNTD(&#13;&#10;        IF [direction] = &quot;Other -&gt; OF&quot;&#13;&#10;        AND [target_year] &lt; 2028&#13;&#10;        THEN [source_id]&#13;&#10;        END&#13;&#10;    )&#13;&#10;}' />
      </column>
      <column caption='incoming_genre' datatype='string' name='[Calculation_1489342818275354]' role='dimension' type='nominal'>
