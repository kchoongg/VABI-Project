    <worksheet name='07_Genre_Exchange'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Arial'>Oceanus Folk’s Genre Exchange: What It Influenced vs What Influenced It</run>
            <run>Æ&#10;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='oceanus_folk_spread' name='federated.1ohy3590s5o63h12rtt2p1qkbtfw' />
          </datasources>
          <datasource-dependencies datasource='federated.1ohy3590s5o63h12rtt2p1qkbtfw'>
            <column caption='Counterpart Genre' datatype='string' name='[Calculation_1489342780923909]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [direction] = &quot;OF -&gt; Other&quot; THEN [target_genre]&#13;&#10;ELSEIF [direction] = &quot;Other -&gt; OF&quot; THEN [source_genre]&#13;&#10;END' />
            </column>
            <column caption='Genres Influenced by OF' datatype='integer' name='[Calculation_1489342780968966]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [Calculation_1489342780923909] :&#13;&#10;    COUNTD(&#13;&#10;        IF [direction] = &quot;OF -&gt; Other&quot; THEN [target_id] END&#13;&#10;    )&#13;&#10;}' />
            </column>
            <column caption='Genres Influencing OF' datatype='integer' name='[Calculation_1489342781009927]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [Calculation_1489342780923909] :&#13;&#10;    COUNTD(&#13;&#10;        IF [direction] = &quot;Other -&gt; OF&quot; THEN [source_id] END&#13;&#10;    )&#13;&#10;}' />
            </column>
            <column caption='Genres Influencing OF (-)' datatype='integer' name='[Calculation_1489342781046792]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='-[Calculation_1489342781009927]' />
            </column>
            <column caption='Genre Exchange Total' datatype='integer' name='[Calculation_1489342781087753]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_1489342780968966] + [Calculation_1489342781009927]' />
            </column>
            <column caption='Direction' datatype='string' name='[direction]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_1489342780923909]' derivation='None' name='[none:Calculation_1489342780923909:nk]' pivot='key' type='nominal' />
            <column caption='Source Genre' datatype='string' name='[source_genre]' role='dimension' type='nominal' />
            <column caption='Source Id' datatype='integer' name='[source_id]' role='dimension' type='ordinal' />
            <column-instance column='[Calculation_1489342780968966]' derivation='Sum' name='[sum:Calculation_1489342780968966:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1489342781009927]' derivation='Sum' name='[sum:Calculation_1489342781009927:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1489342781046792]' derivation='Sum' name='[sum:Calculation_1489342781046792:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1489342781087753]' derivation='Sum' name='[sum:Calculation_1489342781087753:qk]' pivot='key' type='quantitative' />
            <column caption='Genre' datatype='string' name='[target_genre]' role='dimension' type='nominal' />
