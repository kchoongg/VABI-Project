      <aliases enabled='yes' />
      <column caption='is_sailor_work' datatype='integer' name='[Calculation_1489342834442269]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF NOT ISNULL([work_id (sailor_shift_career.csv)]) THEN 1&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
      <column caption='is_valid_collaborator' datatype='integer' name='[Calculation_1489342835044382]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [role_group] = &quot;contributor&quot;&#13;&#10;AND [source_display_name] &lt;&gt; &quot;Sailor Shift&quot;&#13;&#10;AND ([source_type] = &quot;Person&quot; OR [source_type] = &quot;MusicalGroup&quot;)&#13;&#10;THEN 1&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
      <column caption='sailor_collab_works' datatype='integer' name='[Calculation_1489342835122207]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [source_display_name] :&#13;&#10;    COUNTD(&#13;&#10;        IF [Calculation_1489342835044382] = 1&#13;&#10;        AND [Calculation_1489342834442269] = 1&#13;&#10;        THEN [work_id]&#13;&#10;        END&#13;&#10;    )&#13;&#10;}' />
      </column>
      <column caption='broader_of_works' datatype='integer' name='[Calculation_1489342835179552]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [source_display_name] :&#13;&#10;    COUNTD(&#13;&#10;        IF [Calculation_1489342835044382] = 1&#13;&#10;        AND [Calculation_1489342834442269] = 0&#13;&#10;        AND [work_genre] = &quot;Oceanus Folk&quot;&#13;&#10;        THEN [work_id]&#13;&#10;        END&#13;&#10;    )&#13;&#10;}' />
      </column>
      <column caption='broader_influential_works' datatype='integer' name='[Calculation_1489342835253281]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [source_display_name] :&#13;&#10;    COUNTD(&#13;&#10;        IF [Calculation_1489342835044382] = 1&#13;&#10;        AND [Calculation_1489342834442269] = 0&#13;&#10;        AND [influenced_others_count] &gt; 0&#13;&#10;        THEN [work_id]&#13;&#10;        END&#13;&#10;    )&#13;&#10;}' />
      </column>
      <column caption='is_sailor_collaborator' datatype='string' name='[Calculation_1489342835335202]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1489342835122207] &gt; 0 THEN &quot;Yes&quot;&#13;&#10;ELSE &quot;No&quot;&#13;&#10;END' />
      </column>
      <column caption='bridge_label' datatype='string' name='[Calculation_1489342835388451]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1489342835122207] &gt;= 2&#13;&#10;OR [Calculation_1489342835179552] &gt;= 2&#13;&#10;OR [Calculation_1489342835253281] &gt;= 2&#13;&#10;THEN [source_display_name]&#13;&#10;END' />
      </column>
      <column caption='broader_work_count' datatype='integer' name='[Calculation_1489342847954980]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [source_display_name] :&#13;&#10;    COUNTD(&#13;&#10;        IF [Calculation_1489342835044382] = 1&#13;&#10;        AND [Calculation_1489342834442269] = 0&#13;&#10;        THEN [work_id]&#13;&#10;        END&#13;&#10;    )&#13;&#10;}' />
      </column>
