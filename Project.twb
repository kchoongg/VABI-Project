      <aliases enabled='yes' />
      <column caption='Recent status' datatype='string' name='[Calculation_1489342783905802]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [last_performance_year] &gt;= 2025 THEN&#13;&#10;    &quot;Recent Active&quot;&#13;&#10;ELSE&#13;&#10;    &quot;Older&quot;&#13;&#10;END' />
      </column>
      <column caption='Influence per work' datatype='real' name='[Calculation_1489342786330635]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [num_performed_works] &gt; 0 THEN&#13;&#10;    [performed_work_influence_received] / [num_performed_works]&#13;&#10;END' />
      </column>
      <column caption='notable_rate' datatype='real' name='[Calculation_1489342786416652]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [num_performed_works] &gt; 0 THEN&#13;&#10;    [num_notable_performed_works] / [num_performed_works]&#13;&#10;END' />
      </column>
      <column caption='Candidate Label' datatype='string' name='[Calculation_1489342786723853]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [is_oceanus_folk_artist] = TRUE&#13;&#10;AND [last_performance_year] &gt;= 2025 THEN&#13;&#10;    [artist_display_name]&#13;&#10;END' />
      </column>
      <column caption='influence_per_work_pred' datatype='real' name='[Calculation_1489342809112592]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [num_performed_works] &gt; 0 THEN&#13;&#10;    [performed_work_influence_received] / [num_performed_works]&#13;&#10;END' />
      </column>
      <column caption='notable_rate_pred' datatype='real' name='[Calculation_1489342809178129]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [num_performed_works] &gt; 0 THEN&#13;&#10;    [num_notable_performed_works] / [num_performed_works]&#13;&#10;END' />
      </column>
      <column caption='recent_status_2040' datatype='string' name='[Calculation_1489342809227282]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [last_performance_year] &gt;= 2035 THEN&#13;&#10;    &quot;Active near 2040&quot;&#13;&#10;ELSEIF [last_performance_year] &gt;= 2030 THEN&#13;&#10;    &quot;Somewhat recent&quot;&#13;&#10;ELSE&#13;&#10;    &quot;Older&quot;&#13;&#10;END' />
      </column>
      <column caption='influence_component' datatype='real' name='[Calculation_1489342809264147]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1489342809112592] &gt;= 10 THEN 40&#13;&#10;ELSE [Calculation_1489342809112592] / 10 * 40&#13;&#10;END' />
      </column>
      <column caption='notable_component' datatype='real' name='[Calculation_1489342809313300]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1489342809178129] * 30' />
      </column>
      <column caption='collaboration_component' datatype='real' name='[Calculation_1489342809370645]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [num_all_contributed_works] &gt;= 20 THEN 15&#13;&#10;ELSE [num_all_contributed_works] / 20 * 15&#13;&#10;END' />
      </column>
      <column caption='recency_component' datatype='integer' name='[Calculation_1489342809423894]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [last_performance_year] &gt;= 2035 THEN 15&#13;&#10;ELSEIF [last_performance_year] &gt;= 2030 THEN 8&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
      <column caption='prediction_score' datatype='real' name='[Calculation_1489342809473047]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1489342809264147]&#13;&#10;+ [Calculation_1489342809313300]&#13;&#10;+ [Calculation_1489342809370645]&#13;&#10;+ [Calculation_1489342809423894]' />
      </column>
