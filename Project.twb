    <worksheet name='10_Next_Oceanus_Folk_Stars'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Who Are the Next Oceanus Folk Stars?</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Æ </run>
            <run>Æ&#10;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='artist_careers' name='federated.0pmjslx1u4ix0d193kgj00zip2bz' />
          </datasources>
          <datasource-dependencies datasource='federated.0pmjslx1u4ix0d193kgj00zip2bz'>
            <column caption='influence_per_work_pred' datatype='real' name='[Calculation_1489342809112592]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [num_performed_works] &gt; 0 THEN&#13;&#10;    [performed_work_influence_received] / [num_performed_works]&#13;&#10;END' />
            </column>
            <column caption='notable_rate_pred' datatype='real' name='[Calculation_1489342809178129]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [num_performed_works] &gt; 0 THEN&#13;&#10;    [num_notable_performed_works] / [num_performed_works]&#13;&#10;END' />
            </column>
            <column caption='recent_status_2040' datatype='string' name='[Calculation_1489342809227282]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [last_performance_year] &gt;= 2035 THEN&#13;&#10;    &quot;Active near 2040&quot;&#13;&#10;ELSEIF [last_performance_year] &gt;= 2030 THEN&#13;&#10;    &quot;Somewhat recent&quot;&#13;&#10;ELSE&#13;&#10;    &quot;Older&quot;&#13;&#10;END' />
            </column>
            <column caption='influence_component' datatype='real' name='[Calculation_1489342809264147]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Calculation_1489342809112592] &gt;= 10 THEN 40&#13;&#10;ELSE [Calculation_1489342809112592] / 10 * 40&#13;&#10;END' />
            </column>
            <column caption='notable_component' datatype='real' name='[Calculation_1489342809313300]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_1489342809178129] * 30' />
            </column>
            <column caption='collaboration_component' datatype='real' name='[Calculation_1489342809370645]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [num_all_contributed_works] &gt;= 20 THEN 15&#13;&#10;ELSE [num_all_contributed_works] / 20 * 15&#13;&#10;END' />
            </column>
            <column caption='recency_component' datatype='integer' name='[Calculation_1489342809423894]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [last_performance_year] &gt;= 2035 THEN 15&#13;&#10;ELSEIF [last_performance_year] &gt;= 2030 THEN 8&#13;&#10;ELSE 0&#13;&#10;END' />
            </column>
            <column caption='prediction_score' datatype='real' name='[Calculation_1489342809473047]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_1489342809264147]&#13;&#10;+ [Calculation_1489342809313300]&#13;&#10;+ [Calculation_1489342809370645]&#13;&#10;+ [Calculation_1489342809423894]' />
            </column>
            <column caption='Artist Display Name' datatype='string' name='[artist_display_name]' role='dimension' type='nominal' />
            <column caption='Artist Type' datatype='string' name='[artist_type]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_1489342809227282]' derivation='Attribute' name='[attr:Calculation_1489342809227282:nk]' pivot='key' type='nominal' />
            <column-instance column='[artist_display_name]' derivation='Attribute' name='[attr:artist_display_name:nk]' pivot='key' type='nominal' />
            <column-instance column='[last_performance_year]' derivation='Attribute' name='[attr:last_performance_year:qk]' pivot='key' type='quantitative' />
            <column-instance column='[primary_genre]' derivation='Attribute' name='[attr:primary_genre:nk]' pivot='key' type='nominal' />
            <column caption='Is Oceanus Folk Artist' datatype='boolean' name='[is_oceanus_folk_artist]' role='dimension' type='nominal' />
            <column caption='Last Performance Year' datatype='integer' name='[last_performance_year]' role='dimension' type='quantitative' />
            <column-instance column='[Calculation_1489342809227282]' derivation='None' name='[none:Calculation_1489342809227282:nk]' pivot='key' type='nominal' />
            <column-instance column='[artist_display_name]' derivation='None' name='[none:artist_display_name:nk]' pivot='key' type='nominal' />
            <column-instance column='[artist_type]' derivation='None' name='[none:artist_type:nk]' pivot='key' type='nominal' />
            <column-instance column='[is_oceanus_folk_artist]' derivation='None' name='[none:is_oceanus_folk_artist:nk]' pivot='key' type='nominal' />
            <column-instance column='[num_performed_works]' derivation='None' name='[none:num_performed_works:qk]' pivot='key' type='quantitative' />
            <column caption='Num All Contributed Works' datatype='integer' name='[num_all_contributed_works]' role='measure' type='quantitative' />
            <column caption='Num Notable Performed Works' datatype='integer' name='[num_notable_performed_works]' role='measure' type='quantitative' />
            <column caption='Num Performed Works' datatype='integer' name='[num_performed_works]' role='measure' type='quantitative' />
