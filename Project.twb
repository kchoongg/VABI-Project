    <worksheet name='08_Rising_Star_Map'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>What Does a Rising Star Look Like?</run>
            <run>Æ&#10;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='artist_careers' name='federated.0pmjslx1u4ix0d193kgj00zip2bz' />
          </datasources>
          <datasource-dependencies datasource='federated.0pmjslx1u4ix0d193kgj00zip2bz'>
            <column caption='Recent status' datatype='string' name='[Calculation_1489342783905802]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [last_performance_year] &gt;= 2025 THEN&#13;&#10;    &quot;Recent Active&quot;&#13;&#10;ELSE&#13;&#10;    &quot;Older&quot;&#13;&#10;END' />
            </column>
            <column caption='Influence per work' datatype='real' name='[Calculation_1489342786330635]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [num_performed_works] &gt; 0 THEN&#13;&#10;    [performed_work_influence_received] / [num_performed_works]&#13;&#10;END' />
            </column>
            <column caption='Candidate Label' datatype='string' name='[Calculation_1489342786723853]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [is_oceanus_folk_artist] = TRUE&#13;&#10;AND [last_performance_year] &gt;= 2025 THEN&#13;&#10;    [artist_display_name]&#13;&#10;END' />
            </column>
            <column caption='Artist Display Name' datatype='string' name='[artist_display_name]' role='dimension' type='nominal' />
            <column caption='Artist Id' datatype='integer' name='[artist_id]' role='dimension' type='ordinal' />
