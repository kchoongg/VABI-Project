    <worksheet name='09_Artists_Comparison (2)'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Tableau Bold'>Comparing Three Careers: Sailor Shift, Yang Wan, and The Brine Choir</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Each dot represents a performed notable work; multiple works in the same year may overlap. </run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='artist_work_timeline' name='federated.1d52px415op60n17qi20j0ogvujr' />
          </datasources>
          <datasource-dependencies datasource='federated.1d52px415op60n17qi20j0ogvujr'>
            <column caption='notable_works_per_year' datatype='integer' name='[Calculation_1757625842864128]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [source_display_name], [work_release_year] :&#13;&#10;    COUNTD(&#13;&#10;        IF [notable] = TRUE THEN [work_name] END&#13;&#10;    )&#13;&#10;}' />
            </column>
