          <datasource-dependencies datasource='federated.1d52px415op60n17qi20j0ogvujr'>
            <column caption='Milestone Label' datatype='string' name='[Calculation_1489342808043535]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [source_display_name] = &quot;Sailor Shift&quot;&#13;&#10;AND [work_name] = &quot;High Tide Heartbeat&quot;&#13;&#10;THEN [work_name]&#13;&#10;&#13;&#10;ELSEIF [source_display_name] = &quot;Yang Wan&quot;&#13;&#10;AND [work_name] = &quot;Perfect Harmony&quot;&#13;&#10;THEN [work_name]&#13;&#10;&#13;&#10;ELSEIF [source_display_name] = &quot;The Brine Choir&quot;&#13;&#10;AND [work_name] = &quot;Drifting Between the Stars and the Sea&quot;&#13;&#10;THEN [work_name]&#13;&#10;&#13;&#10;END' />
            </column>
            <column-instance column='[work_genre]' derivation='Attribute' name='[attr:work_genre:nk]' pivot='key' type='nominal' />
            <column caption='Edge Type' datatype='string' name='[edge_type]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_1489342808043535]' derivation='None' name='[none:Calculation_1489342808043535:nk]' pivot='key' type='nominal' />
            <column-instance column='[edge_type]' derivation='None' name='[none:edge_type:nk]' pivot='key' type='nominal' />
            <column-instance column='[notable]' derivation='None' name='[none:notable:nk]' pivot='key' type='nominal' />
            <column-instance column='[source_display_name]' derivation='None' name='[none:source_display_name:nk]' pivot='key' type='nominal' />
            <column-instance column='[work_name]' derivation='None' name='[none:work_name:nk]' pivot='key' type='nominal' />
            <column-instance column='[work_release_year]' derivation='None' name='[none:work_release_year:qk]' pivot='key' type='quantitative' />
            <column caption='Notable' datatype='boolean' name='[notable]' role='dimension' type='nominal' />
            <column caption='Source Display Name' datatype='string' name='[source_display_name]' role='dimension' type='nominal' />
            <column caption='Work Genre' datatype='string' name='[work_genre]' role='dimension' type='nominal' />
            <column caption='Work Name' datatype='string' name='[work_name]' role='dimension' type='nominal' />
            <column caption='Work Release Year' datatype='integer' name='[work_release_year]' role='dimension' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.1d52px415op60n17qi20j0ogvujr].[none:edge_type:nk]'>
            <groupfilter function='member' level='[none:edge_type:nk]' member='&quot;PerformerOf&quot;' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
          </filter>
          <filter class='categorical' column='[federated.1d52px415op60n17qi20j0ogvujr].[none:notable:nk]'>
            <groupfilter function='member' level='[none:notable:nk]' member='true' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
